        <script><![CDATA[(function executeRule(current, previous /*null when async*/) {

	// Step 1: Instantiate GlideRecord against the User table to look up the requestor
    var userGR = new GlideRecord('sys_user');
    
    // Step 2: Search for the SysID matching the record's requestor
    if (userGR.get(current.requestor)) {
        var managerID = userGR.manager;
        
        if (managerID) {
            // Step 3: Write a system diagnostic log confirming execution
            gs.info('InfoRequest App: Automatically routing ticket to manager ID: ' + managerID);
            
            // Step 4: Set the assigned_to field to the manager and update the ticket state
            current.assigned_to = managerID;
            current.state = 'under_review'; 
            current.update(); // Update the record in the database
        } else {
            gs.warn('InfoRequest App: No manager was found on the profile of user ' + current.requestor.getDisplayValue());
        }
    }

})(current, previous);]]></script>
